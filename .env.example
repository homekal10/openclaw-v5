# ═══════════════════════════════════════════════════════════════════════════════
# OpenClaw v5.0 — Environment Variables Template for Render Deployment
# Copy to telegram.env (local) or set in Render Dashboard → Environment
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core (REQUIRED) ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
DASHBOARD_PORT=10000
TELEGRAM_BOT_TOKEN=
ADMIN_USER_ID=

# ── Supabase (REQUIRED for persistence) ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Market Data APIs ─────────────────────────────────────────────────────────
COINAPI_KEY=
COINAPI_BASE=https://rest.coinapi.io/v1
BINANCE_API_KEY=
BINANCE_UID=

# ── AI/LLM Providers ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER=deepseek-reasoner
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-fast
AICC_API_KEY=
AICC_BASE_URL=https://api.ai.cc/v1

# ── Local AI (not needed on Render) ──────────────────────────────────────────
# AI_BASE_URL=http://localhost:1234
# MODEL_FAST=google/gemma-3-4b
# MODEL_FALLBACK=zai-org/glm-4.6v-flash
# MODEL_PRIMARY=phi-3.1-mini-128k-instruct

# ── Risk Engine APIs ─────────────────────────────────────────────────────────
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com/v3
REMORA_API_KEY=
REMORA_BASE_URL=https://api.remorarisk.com/v1

# ── Security ─────────────────────────────────────────────────────────────────
BOT_INGEST_SECRET=
BRIDGE_DEBUG=false

# ── Dashboard URL (update after Render deploy) ───────────────────────────────
DASHBOARD_URL=https://openclaw-v5.onrender.com
